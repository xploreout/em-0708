JWT_SECRET=replace-with-a-long-random-secret-string
PORT=3001

# Default passwords (used only when initializing passwords.json for the first time)
PASSWORD_CALENDAR=calendar123
PASSWORD_PRAISE_TEAM=praise123
PASSWORD_WORSHIP=worship123
PASSWORD_ADMIN=admin123

# Cloudinary — for congregation member photos (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email — for monthly duty reminders (Gmail: use an App Password, not your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=ACBCC EM <your-gmail@gmail.com>
