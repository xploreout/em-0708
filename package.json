    "react-dom": "^18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-icons": "^5.5.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.8.1",
    "simple-icons": "^15.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.2.1",
